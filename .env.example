# ========================================
# 母婴社区平台 环境配置示例
# 复制此文件为 .env 并根据实际情况修改
# ========================================

# 服务端口
PORT=3001

# 运行环境: development / production
NODE_ENV=development

# ========================================
# JWT 配置
# ========================================
# JWT 签名密钥 (生产环境务必修改为复杂随机字符串!)
JWT_SECRET=momcare-dev-secret-key-2024-please-change-in-production
# JWT 过期时间
JWT_EXPIRES_IN=7d

# ========================================
# 数据库配置 (SQLite)
# ========================================
# SQLite 数据库文件路径 (留空使用默认路径: 项目根目录/database.sqlite)
# DB_PATH=./data/database.sqlite
